{
  "name": "no-tmpl",
  "displayName": "无模板参数",
  "description": "argTemplate 留空，参数按 inputs 定义顺序直接追加到命令行",
  "version": "1.0.0",
  "os": ["linux", "macos"],
  "category": "开发",
  "icon": "utilities-terminal",
  "command": "bash",
  "args": ["tmpl.sh"],
  "runMode": "oneshot",
  "outputMode": "stream",
  "inputs": [
    {
      "name": "title",
      "type": "text",
      "label": "标题",
      "description": "任务标题",
      "required": true,
      "default": "my-task"
    },
    {
      "name": "mode",
      "type": "choice",
      "label": "模式",
      "choices": ["预览", "执行", "回滚"],
      "default": "预览"
    },
    {
      "name": "retries",
      "type": "int",
      "label": "重试次数",
      "min": 0,
      "max": 10,
      "default": "3"
    }
  ]
}
